# ==========================================================================
# AstraNova OFFICIAL WEBSITE - ENVIRONMENT VARIABLES TEMPLATE
# ==========================================================================
# 
# 本ファイルはローカル開発環境およびVercel本番環境に必要な環境変数のテンプレートです。
# 本番公開時およびローカル検証時は、本ファイルをコピーして「.env」ファイルを作成し、
# 実際のAPIキーを設定してください。（.envは絶対にGitにコミットしないでください）

# 1. Resend APIキー (メール配信用)
# 例: re_xxxxxxxxxxxxxxxxxxxxxx
# 取得元: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# 2. Cloudflare Turnstile シークレットキー (Botスパム検証用)
# 例: 0x4AAAAAA...
# 取得元: https://dash.cloudflare.com (Turnstile セクション)
# 開発テスト用（常に検証合格するキー）: 0x4AAAAAA... (※Cloudflareドキュメント参照)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# 3. 通知先メールアドレス (お問い合わせの受信先)
# 例: manager@astranova-esports.com
TO_EMAIL=your_receive_email_here
